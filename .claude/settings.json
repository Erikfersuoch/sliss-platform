{
  "permissions": {
    "deny": [
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git push *--force*)",
      "Bash(git push *--delete*)"
    ],
    "allow": [
      "mcp__claude_ai_Vercel__list_deployments",
      "mcp__claude_ai_Vercel__get_deployment",
      "mcp__claude_ai_Vercel__list_teams",
      "mcp__claude_ai_Vercel__list_projects",
      "mcp__claude_ai_Vercel__get_runtime_logs",
      "Bash(git fetch *)",
      "Bash(git status*)",
      "Bash(git log*)",
      "Bash(git diff*)",
      "Bash(git show*)",
      "Bash(git rev-parse*)",
      "Bash(git branch*)",
      "Bash(git stash*)",
      "Bash(git merge --ff-only *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git push *)",
      "Bash(npm run lint)",
      "Bash(npm run build)",
      "Bash(npm test)",
      "Bash(npm test *)",
      "Bash(npm run *)",
      "PowerShell(npm run *)",
      "Bash(bash docs/check-sync.sh)",
      "Bash(bash docs/check-sync.sh --fix)",
      "Bash(bash docs/check-contesto.sh)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$CLAUDE_PROJECT_DIR\" && bash scripts/session-start.sh 2>/dev/null || true"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$CLAUDE_PROJECT_DIR\" && bash scripts/check-agent-map.sh 2>/dev/null || true"
          }
        ]
      }
    ]
  }
}
